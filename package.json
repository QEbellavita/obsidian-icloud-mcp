{
  "name": "obsidian-icloud-mcp",
  "version": "1.0.0",
  "description": "MCP server for Obsidian vaults that survives iCloud \u2014 reads, searches and writes notes without hanging on evicted files",
  "license": "MIT",
  "main": "server.js",
  "bin": {
    "obsidian-icloud-mcp": "server.js"
  },
  "files": [
    "server.js",
    "src/"
  ],
  "scripts": {
    "start": "node server.js",
    "test": "NODE_OPTIONS=--experimental-vm-modules jest",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "obsidian",
    "notes",
    "icloud",
    "markdown"
  ],
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "jest": "^29.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/QEbellavita/obsidian-icloud-mcp.git"
  },
  "homepage": "https://github.com/QEbellavita/obsidian-icloud-mcp#readme",
  "bugs": {
    "url": "https://github.com/QEbellavita/obsidian-icloud-mcp/issues"
  },
  "author": "Belinda Switzer (https://github.com/QEbellavita)"
}
